    {
      "parameters": {
        "jsCode": "// Input: items[0].json.html contains the website's HTML content\n\nconst html = $input.first().json.data.toLowerCase();\n\n// Simple checks for chatbot presence by identifying common chatbot elements or keywords\nconst chatbotIndicators = [\n  'chatbot',               // common keyword in class/id/element\n  'livechat',              // popular live chat widget identifier\n  'intercom',              // Intercom chat widget\n  'tawk.to',               // Tawk.to chat widget script\n  'drift',                 // Drift chat widget\n  'zendesk chat',          // Zendesk chat\n  'olark',                 // Olark chat\n  'freshchat',             // Freshchat widget\n  'hubspot',               // HubSpot chat widget\n];\n\nconst chatbotExists = chatbotIndicators.some(indicator => html.includes(indicator));\n\nreturn [\n  {\n    json: {\n      chatbotExists\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
