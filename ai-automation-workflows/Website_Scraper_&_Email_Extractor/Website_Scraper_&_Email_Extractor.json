    {
      "parameters": {
        "jsCode": "// Input: items[0].json.html contains the website's HTML content\n\nconst html = $('Get the website HTML').first().json.data.toLowerCase();\n// Email regex to find email addresses in the HTML\nconst emailRegex = /[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\\.[a-z]{2,}/g;\nconst emailsFound = html.match(emailRegex) || [];\n\nreturn [\n  {\n    json: {\n      emailsFound,\n      }\n  }\n];\n"
      },
